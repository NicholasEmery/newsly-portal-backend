# MongoDB connection string para Prisma
DATABASE_URL="sua-string-de-conexao-mongodb-aqui"

# JWT
JWT_SECRET="troque-por-um-segredo-forte"
# Tempo de expiração do access token (ex.: 15d = 15 dias)
ACCESS_EXPIRES_IN=15d
# Dias de expiração do refresh token (ex.: 30 dias)
REFRESH_EXPIRES_DAYS=30

# Google OAuth2
GOOGLE_CLIENT_ID="seu-google-client-id"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# Frontend
FRONTEND_URL="http://localhost:3000"
AUTH_FRONTEND_ORIGIN="http://localhost:3000"
# Email SMTP
# Configurações para envio de emails (ex.: Gmail, SendGrid)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-app"
EMAIL_FROM="seu-email@gmail.com"
# Uploads
# Diretório para uploads em desenvolvimento
UPLOAD_DIR_DEV=uploadsFile
# Diretório para uploads em produção/docker
UPLOAD_DIR_PROD="/app/uploadsFile"

# Porta do backend
# Porta onde o servidor NestJS roda
PORT=3001